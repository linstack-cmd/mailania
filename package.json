{
  "name": "mailania",
  "version": "0.1.0",
  "description": "Minimal Gmail client with OAuth login and inbox listing, styled with Flow CSS",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"tsx src/server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "api": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@flow-css/core": "^1.4.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@flow-css/vite": "^1.4.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
