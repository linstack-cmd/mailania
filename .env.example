# --- Server ---
PORT=3001

# How many inbox messages to show
INBOX_LIMIT=25

# --- Secret Party (required) ---
# Mailania uses Secret Party as the single source of truth for OAuth config.
# Required secrets in Secret Party environment:
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
# Optional secret:
#   FRONTEND_ORIGIN
SECRET_PARTY_API_URL=https://secret-party.probablydanny.com
SECRET_PARTY_ENVIRONMENT_ID=your-environment-id
SECRET_PARTY_PRIVATE_KEY_BASE64=your-api-client-private-key-base64
