# --- Server ---
PORT=3001

# How many inbox messages to show
INBOX_LIMIT=25

# =============================================================================
# LOCAL DEV MODE (no Google OAuth required)
# =============================================================================
# Set LOCAL_DEV_NO_AUTH=true to skip Google sign-in and Secret Party entirely.
# The app serves mock inbox data and bypasses authentication.
# Only requires DATABASE_URL (Postgres). SESSION_SECRET is auto-generated if
# not provided.
#
# Quick start:
#   LOCAL_DEV_NO_AUTH=true
#   DATABASE_URL=postgresql://user:pass@localhost:5432/mailania
#
# Optional (enables real LLM triage on mock data):
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_MODEL=claude-sonnet-4-20250514

LOCAL_DEV_NO_AUTH=false

# =============================================================================
# PRODUCTION MODE (Secret Party + Google OAuth)
# =============================================================================
# Mailania uses Secret Party as the single source of truth for secrets.
# Required secrets in Secret Party environment:
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   DATABASE_URL        — CockroachDB/Postgres connection string
#   SESSION_SECRET      — random 32+ byte hex string for signing session cookies
# Optional secrets:
#   FRONTEND_ORIGIN
#   ANTHROPIC_API_KEY
#   ANTHROPIC_MODEL
SECRET_PARTY_API_URL=https://secret-party.probablydanny.com
SECRET_PARTY_ENVIRONMENT_ID=your-environment-id
SECRET_PARTY_PRIVATE_KEY_BASE64=your-api-client-private-key-base64

# --- Fallbacks (used only if not in Secret Party) ---
# DATABASE_URL=postgresql://user:pass@host:26257/mailania?sslmode=verify-full
# SESSION_SECRET=generate-with-node-e-crypto-randomBytes-32-toString-hex
