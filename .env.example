# --- Google OAuth2 credentials (from Google Cloud Console) ---
# Required if NOT using Secret Party, or as fallback.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# --- Server ---
PORT=3001

# Optional. Where to send browser after OAuth callback.
# Dev: http://localhost:5173
# Dokploy: https://mailania.probablydanny.com
FRONTEND_ORIGIN=http://localhost:5173

# How many inbox messages to show
INBOX_LIMIT=25

# --- Secret Party (optional) ---
# When all three are set, secrets are fetched from Secret Party at startup.
# Values from Secret Party take priority over the GOOGLE_* / FRONTEND_ORIGIN
# env vars above, which then serve as fallbacks.
#
# SECRET_PARTY_API_URL=https://secret-party.probablydanny.com
# SECRET_PARTY_ENVIRONMENT_ID=your-environment-id
# SECRET_PARTY_PRIVATE_KEY_BASE64=your-api-client-private-key-base64
